{
  "name": "jest-puppeteer-webpack",
  "private": "true",
  "version": "1.0.0",
  "main": "src/e2e.server.js",
  "scripts": {
    "start": "webpack serve --mode development --port 9000",
    "test:e2e": "jest src/e2e.test.js",
    "test": "start-server-and-test start http://localhost:9000 test:e2e",
    "build": "webpack --mode production"
  },
  "author": "Valerii Grishin",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "html-loader": "^5.1.0",
    "html-webpack-plugin": "^5.6.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.0.0",
    "puppeteer": "^24.39.1",
    "start-server-and-test": "^2.1.2",
    "style-loader": "^4.0.0",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "jest": {
    "projects": [
      {
        "displayName": "unit",
        "testEnvironment": "jsdom",
        "testMatch": ["<rootDir>/src/__tests__/**/*.test.js"],
        "transform": {
          "^.+\\.js$": "babel-jest"
        }
      },
      {
        "displayName": "e2e",
        "testEnvironment": "node",
        "testMatch": ["<rootDir>/src/e2e.test.js"],
        "transform": {
          "^.+\\.js$": "babel-jest"
        }
      }
    ]
  }
}